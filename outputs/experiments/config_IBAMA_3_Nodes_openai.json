{
    "llm": {
        "models": {
            "openai": {
                "model_name": "gpt-5.4-nano",
                "temperature": 0.0
            },
            "aws": {
                "model_name": "openai.gpt-oss-120b-1:0",
                "region": "us-east-1",
                "temperature": 0.0
            }
        },
        "provider": "openai"
    },
    "experiment": {
        "name": "IBAMA_Entity_Extraction",
        "mlflow_run": "IBAMA_3_Nodes_openai",
        "architecture": "3_nodes",
        "dataset_path": "artefatos/ner_datasets/investigacao_acidentes_ibama_agent.csv",
        "train_split_ratio": 0.99
    },
    "domain": {
        "name": "IBAMA_Report_Descriptions",
        "tasks": [
            {
                "name": "extract_phenomenon",
                "prompt_path": "artefatos/prompts/ibama/extract_phenomenon.txt",
                "entities": [
                    "phenomenon"
                ]
            },
            {
                "name": "extract_cause",
                "prompt_path": "artefatos/prompts/ibama/extract_cause.txt",
                "entities": [
                    "cause"
                ]
            },
            {
                "name": "extract_consequence",
                "prompt_path": "artefatos/prompts/ibama/extract_consequence.txt",
                "entities": [
                    "consequence"
                ]
            }
        ],
        "judge": {
            "prompt_path": "artefatos/prompts/ibama/judge.txt"
        }
    }
}